# Discord ボットトークン（Developer Portal で取得）
DISCORD_TOKEN=

# LLM フォールバックを使う場合のみ。空ならフォールバックは無効（マルコフのみで動く）
ANTHROPIC_API_KEY=

# 開発・検証用。サーバー（ギルド）ID を入れると、そのサーバー限定で
# スラッシュコマンドが即時反映される。空なら全体同期（反映に時間がかかる）。
MUNO_GUILD_ID=

# キャラ名（呼びかけや一人称に使う）
MUNO_NAME=ムノ

# 反応する確率（メンションされなくても 0.0〜1.0 の確率で口を挟む）
MUNO_RANDOM_REPLY_RATE=0.15

# LLM にフォールバックする最低文字数（マルコフ生成がこれ未満なら助けを呼ぶ）
MUNO_MARKOV_MIN_LEN=6
